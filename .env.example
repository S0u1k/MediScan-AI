# MediScan AI — Environment variables template
# Copy this file to ".env.local" and fill in real values.
# NEVER commit .env.local or real keys to version control.

# ---- Firebase (client config) ----
# Public Firebase web config. Safe to expose to the browser, but still keep
# your real values in .env.local rather than committing them.
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# ---- Gemini (server only) ----
# Used ONLY inside server-side API routes (app/api/*). Never prefix with
# NEXT_PUBLIC_ and never expose to the frontend.
GEMINI_API_KEY=your_gemini_api_key
